# Dependencies (any node_modules variant, incl. partial/broken install dirs)
node_modules/
node_modules.*/
**/node_modules/
**/node_modules.*/
.pnpm-store/
.pnpm*/

# Broken/partial install leftovers from failed pnpm runs
*.broken*/
*.partial/
*_partial/
*_tmp*

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*.local
.env.*.production

# Database
*.db
*.db-shm
*.db-wal
.prisma/migrations/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Temporary files
.tmp/
*.tmp

# Lock files (yarn/npm not used). pnpm-lock.yaml excluded: the current copy is a
# leftover from a failed install run and is not valid — regenerate after a clean install.
yarn.lock
package-lock.json
pnpm-lock.yaml

# Prisma
prisma/migrations/
.prisma

# Cache
.cache/

# Claude Code local agent artifacts (working files, not part of the app)
.claude/

# gstack skill artifacts (QA reports, timelines, etc.)
.gstack/

# Local memory/runtime state
.env.local
.env.*.local
