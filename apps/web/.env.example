# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=Adaptive Learning Tutor
APP_DESCRIPTION=Installable AI-native tutor for Swiss apprenticeship preparation

# Environment
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/adaptive_learning_tutor?schema=public

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-key

# Security
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# AI Provider (Mock in development)
PROVIDER_MODE=mock
PROVIDER_API_KEY=
PROVIDER_API_URL=
PROVIDER_MODEL=
PROVIDER_TIMEOUT=30000
PROVIDER_MAX_RETRIES=3

# Usage Budget (per user per day in minutes of API usage)
DAILY_USAGE_BUDGET=120

# PWA
PWA_MANIFEST_URL=/manifest.json
PWA_THEME_COLOR=#2563eb
PWA_BACKGROUND_COLOR=#ffffff

# Feature Flags
ENABLE_MOCK_PROVIDER=true
ENABLE_DIAGNOSTIC=true
ENABLE_PERSIAN_LANGUAGE=true
ENABLE_DETAILED_EXPLANATIONS=true

# Analytics (optional)
SENTRY_DSN=
