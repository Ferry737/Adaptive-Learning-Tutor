{
  "name": "adaptive-learning-tutor",
  "version": "0.0.0",
  "private": true,
  "description": "Installable AI-native tutor for Swiss apprenticeship preparation",
  "scripts": {
    "dev": "pnpm -F @adaptive/web dev",
    "build": "pnpm -F @adaptive/web build",
    "start": "pnpm -F @adaptive/web start",
    "test": "tsx --test apps/web/lib/demo-learning.test.ts",
    "test:unit": "tsx --test apps/web/lib/demo-learning.test.ts",
    "db:migrate": "pnpm -F @adaptive/learning-engine db:migrate",
    "db:seed": "pnpm -F @adaptive/learning-engine db:seed",
    "db:reset": "pnpm -F @adaptive/learning-engine db:reset",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check": "tsc --noEmit"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.34.5"
}
